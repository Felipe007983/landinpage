generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(uuid())
  name          String
  cpf           String   @unique
  email         String   @unique
  phone         String
  password_hash String
  address       String?
  profilePic    String?
  role          String   @default("USER") // USER, ADMIN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orders        Order[]
  creditCards   CreditCard[]
}

model Championship {
  id          String   @id @default(uuid())
  name        String
  description String
  date        DateTime
  location    String
  banner      String?
  priceComp   Float    // Preço para competidor
  priceVis    Float    // Preço para visitante
  status      String   @default("OPEN") // OPEN, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
}

model Order {
  id              String       @id @default(uuid())
  userId          String
  championshipId  String
  type            String       // "COMPETITOR" or "VISITOR"
  paymentStatus   String       // "PENDING", "APPROVED", "FAILED"
  amount          Float
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id])
  championship    Championship @relation(fields: [championshipId], references: [id])
  ticket          Ticket?
}

model Ticket {
  id          String   @id @default(uuid())
  uuid        String   @unique @default(uuid()) // UUID for QRCode reading
  orderId     String   @unique
  status      String   @default("VALID") // "VALID" or "USED"
  createdAt   DateTime @default(now())
  validatedAt DateTime?

  order       Order    @relation(fields: [orderId], references: [id])
}

model CreditCard {
  id           String   @id @default(uuid())
  userId       String
  maskedNumber String
  expiry       String
  token        String   // Simulando token do gateway (pagarme/stripe)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id])
}